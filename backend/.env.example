# Use api.example.com after DNS points to the server.
# For a temporary IP-only smoke test, set API_DOMAIN=:80 and visit http://<server-ip>/api/v1/ready.
API_DOMAIN=api.example.com

MYSQL_DATABASE=drone_v2
MYSQL_USER=drone
MYSQL_PASSWORD=replace_with_a_long_random_password
MYSQL_ROOT_PASSWORD=replace_with_a_different_long_random_password

ENABLE_RESET_ENDPOINT=false
ENABLE_SNAPSHOT_WRITE_ENDPOINT=false
INTEGRATION_MODE=sandbox

# Exact HTTPS origins, comma-separated. Production rejects *.
CORS_ALLOW_ORIGIN=https://app.example.com

# Closed beta uses sandbox. Set live only after every provider endpoint and secret is configured.
SMS_PROVIDER=http
SMS_HTTP_ENDPOINT=
SMS_HTTP_AUTH_HEADER=
SMS_HTTP_AUTH_TOKEN=
SMS_HTTP_AUTH_HEADER_NAME=Authorization
SMS_HTTP_TEMPLATE_ID=
SMS_HTTP_TEMPLATE_SIGN=
# Or use ALIYUN_SMS_* / TENCENT_SMS_* provider-specific endpoint, auth, template and sign variables.
PROVIDER_PAYMENT_PREPAY_URL=
PROVIDER_PAYMENT_NOTIFY_SECRET=
PROVIDER_AIRSPACE_APPLY_URL=
PROVIDER_INSURANCE_QUOTE_URL=
PROVIDER_CREDIT_SCORE_URL=
PROVIDER_DRONE_ARM_URL=
PROVIDER_HTTP_AUTH_HEADER=
