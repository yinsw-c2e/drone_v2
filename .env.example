# Local map integration. Do not commit real values.
VITE_AMAP_WEB_KEY=
VITE_AMAP_SECURITY_CODE=
VITE_AMAP_WEB_SERVICE_KEY=

# Backend API. Production release must use a real HTTPS domain, not localhost.
VITE_BACKEND_URL=
VITE_DISABLE_BACKEND=

# External provider selection.
# Local/test can use mock. Production must use bridge.
VITE_PROVIDER_MODE=mock
# Production should normally point to the backend bridge: https://api.example.com/api/v1/provider
VITE_PROVIDER_BRIDGE_URL=
# Must match backend PROVIDER_BRIDGE_AUTH_TOKEN.
VITE_PROVIDER_BRIDGE_TOKEN=

# WeChat mini-program release preflight.
UNI_APP_ID=
MP_WEIXIN_APPID=
MP_WEIXIN_URL_CHECK=true
MP_WEIXIN_REQUEST_DOMAINS=
MP_WEIXIN_BUSINESS_DOMAINS=

# Backend production runtime.
APP_ENV=development
CORS_ALLOW_ORIGIN=

# SMS dispatch. Local/test can use mock. Production must use http/aliyun/tencent.
SMS_PROVIDER=mock
SMS_HTTP_ENDPOINT=
SMS_HTTP_AUTH_HEADER=
SMS_HTTP_AUTH_HEADER_NAME=Authorization
SMS_HTTP_TEMPLATE_ID=
SMS_HTTP_TEMPLATE_SIGN=

# Backend provider bridge. Production requires all endpoints and payment notify signing.
PROVIDER_BRIDGE_AUTH_TOKEN=
PROVIDER_PAYMENT_PREPAY_URL=
PROVIDER_PAYMENT_NOTIFY_SECRET=
PROVIDER_AIRSPACE_APPLY_URL=
PROVIDER_INSURANCE_QUOTE_URL=
PROVIDER_CREDIT_SCORE_URL=
PROVIDER_DRONE_ARM_URL=
PROVIDER_HTTP_AUTH_HEADER=
